#!name = Youtube(Music)
#!desc = 过滤广告,画中画,字幕翻译,歌词翻译,支持后台播放
#!icon = https://raw.githubusercontent.com/sooyaaabo/Loon/main/Icon/App-Icon/YouTube.png

[Argument]
blockUpload = switch, true, false, tag = 移除上传按钮, desc = 用于隐藏YouTube底栏的上传按钮
blockShorts = switch, true, false, tag = 移除Shorts按钮, desc = 用于隐藏YouTube底栏的Shorts按钮
blockImmersive = switch, true, false, tag = 移除选段按钮, desc = 用于隐藏YouTube Music底栏的选段按钮
captionLang = select, "zh-Hans", "zh-Hant", "ja", "ko", "en", "off", tag = 字幕翻译语言, desc = 选择翻译为何种语言字幕
lyricLang = select, "zh-Hans", "zh-Hant", "ja", "ko", "en", "off", tag = 歌词翻译语言, desc = 选择翻译为何种语言字幕

[Rewrite]
^https:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad reject-200

[Script]
http-response ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(?:browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch) script-path = https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js, requires-body = true, binary-body-mode = true, tag = 修改处理, argument=[{blockUpload},{blockShorts},{blockImmersive},{captionLang},{lyricLang},{debug}]

[MitM]
hostname = *.googlevideo.com, youtubei.googleapis.com
