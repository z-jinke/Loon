#!name=YouTube(Music)
#!desc=自定义屏蔽并拦截广告
#!author=Jinke,Maasea
#!icon=https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQtbBYovB7sE4Oqo2oxrcJSQZgB9l3cLTOnPA&s

[Rewrite]
^https:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad mock-response-body data-type=text status-code=502

[Argument]
blockUpload=switch, true, false, tag=隐藏-上传, desc=用于YouTube底栏的上传按钮
blockShorts=switch, true, false, tag=隐藏-Shorts, desc=用于YouTube底栏的Shorts按钮
captionLang=select, "zh-Hans", "zh-Hant", "ja", "ko", "en", "off", tag=字幕翻译, desc=选择翻译为何种语言字幕
blockImmersive=switch, true, false, tag=隐藏-选段按钮, desc=用于YouTube Music底栏的选段按
lyricLang=select, "zh-Hans", "zh-Hant", "ja", "ko", "en", "off", tag=歌词翻译, desc=选择翻译为何种语言字幕

[Script]
http-response ^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(?:browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch) script-path=https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js, requires-body=true, binary-body-mode=true, tag =修改屏蔽, argument=[{blockUpload},{blockShorts},{blockImmersive},{captionLang},{lyricLang},{debug}]

[MitM]
hostname = *.googlevideo.com,youtubei.googleapis.com
