#!name=网易云音乐
#!desc=拦截广告
#!icon=https://raw.githubusercontent.com/lige47/QuanX-icon-rule/main/icon/wyy.png

[Argument]
MY=switch, false, true, tag=隐藏-底部漫游
DT=switch, false, true, tag=隐藏-底部笔记
PRSCVPT=switch, false, true, tag=隐藏-推荐歌单
PRST=switch, false, true, tag=隐藏-最近常听
PRRK=switch, false, true, tag=隐藏-排行榜单

[Rewrite]
^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/(?:e?api\/(?:ocpc\/)?ad\/|w?e?api\/search\/default) response-body-json-jq '.data = {}'
^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/(?:delivery\/(batch-)?deliver|moment\/tab\/info\/|side-bar\/mini-program\/music-service\/account|yunbei\/account\/entrance\/) response-body-json-jq '.data = {}'
^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/(?:community\/friends\/fans-group\/artist\/group\/|mine\/applet\/redpoint|music\/songshare\/text\/recommend\/|resniche\/position\/play\/new\/|resniche\/tspopup\/show|resource\/comments?\/musiciansaid\/|user\/sub\/artist) response-body-json-jq '.data = {}'
^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/(?:ios\/version|mlivestream\/entrance\/playpage\/|link\/position\/show\/strategy|link\/scene\/show\/resource|v1\/content\/exposure\/comment\/banner\/) response-body-json-jq '.data = {}'
^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/w?eapi\/(?:activity\/bonus\/playpage\/time\/query|resource-exposure\/|search\/(?:chart\/|rcmd\/keyword\/|specialkeyword\/)) response-body-json-jq '.data = {}'

[Script]
http-response ^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/(link\/(position\/show|page\/discovery\/resource\/show)|(batch|v2\/resource\/comment\/floor\/get)) script-path = https://raw.githubusercontent.com/Keywos/rule/main/script/wy/js/wyres.js, requires-body=true, binary-body-mode=true, tag=广告处理
http-response ^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/link\/home\/framework\/tab script-path = https://raw.githubusercontent.com/Keywos/rule/main/script/wy/js/wyres.js, requires-body=true, binary-body-mode=true, tag=底部处理, argument=[{MY},{DT},{FX}]
http-response ^https:\/\/(?:ipv4|interface\d?)\.music\.163\.com\/eapi\/(?:homepage\/block\/page|link\/page\/rcmd\/(?:block\/resource\/multi\/refresh|resource\/show)) script-path = https://raw.githubusercontent.com/Keywos/rule/main/script/wy/js/wyres.js, requires-body=true, binary-body-mode=true, tag=推荐处理, argument=[{PRGG},{PRRK},{PRDRD},{PRSCVPT},{PRST},{PRRR},{HMPR},{PRMST},{PRCN}]

[MitM]
hostname = interface*.music.163.com, ipv4.music.163.com
